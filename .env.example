# ZoomInfo — do not commit .env or share tokens.

# Option A — Manual token (Developer Portal → Bearer Token → Generate, valid 24h)
ZOOMINFO_ACCESS_TOKEN=

# Option B — Get token directly (no portal): ZoomInfo only allows HTTPS.
# Local HTTPS (no ngrok): add https://localhost:8443/callback in Developer Portal, then:
# ZOOMINFO_REDIRECT_URI=https://localhost:8443/callback
# Or use ngrok: ngrok http 8080, then ZOOMINFO_REDIRECT_URI=https://<ngrok-host>/callback
# ZOOMINFO_CLIENT_ID=
# ZOOMINFO_CLIENT_SECRET=
# ZOOMINFO_REFRESH_TOKEN=   # filled by oauth_capture_refresh_token.py

# Option C — ZoomInfo official client (zi-api-auth-client): username/password → JWT via api.zoominfo.com/authenticate
# ZOOMINFO_USERNAME=
# ZOOMINFO_PASSWORD=
